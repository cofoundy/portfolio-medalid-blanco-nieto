---
import { siteConfig } from "../config";
const { whyMedalid, results } = siteConfig;
---

<section class="py-20 md:py-28 bg-[var(--color-surface-light)]">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Why section -->
    <div class="reveal text-center mb-12">
      <p class="text-sm tracking-widest uppercase text-[var(--color-primary)] mb-4">
        Why Choose
      </p>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold text-[var(--color-primary-dark)]">
        Why Organisations Choose Medalid
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
      {whyMedalid.map((item, i) => (
        <div class={`reveal stagger-${i + 1} bg-[var(--color-surface)] rounded-2xl p-6 card-hover border border-[var(--color-primary-light)]/15`}>
          <div class="w-10 h-10 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center mb-4">
            <div class="w-3 h-3 rounded-full bg-[var(--color-accent)]"></div>
          </div>
          <h3 class="text-lg font-semibold text-[var(--color-primary-dark)]">{item.title}</h3>
          <p class="mt-2 text-sm text-[var(--color-primary-dark)]/70 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <div class="my-16 mx-auto w-16 h-[2px] bar-shimmer rounded-full"></div>

    <!-- Results -->
    <div class="reveal text-center mb-10">
      <h3 class="text-xl sm:text-2xl font-semibold text-[var(--color-primary-dark)]">
        Results Organisations Can Expect
      </h3>
    </div>

    <div class="reveal grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
      {results.map((result) => (
        <div class="flex items-start gap-3 px-4 py-3 rounded-xl bg-[var(--color-surface)] border border-[var(--color-primary-light)]/10">
          <svg class="w-5 h-5 mt-0.5 text-[var(--color-accent)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-[var(--color-primary-dark)]/80">{result}</span>
        </div>
      ))}
    </div>
  </div>
</section>
