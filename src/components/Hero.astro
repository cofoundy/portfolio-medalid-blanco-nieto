---
import { siteConfig } from "../config";
---

<section class="relative min-h-[85vh] flex items-center bg-[var(--color-surface-light)] overflow-hidden">
  <!-- Warm gradient orbs -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[var(--color-surface)] rounded-full blur-[140px] opacity-70 -translate-y-1/4 translate-x-1/6"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[var(--color-primary-light)] rounded-full blur-[140px] opacity-25 translate-y-1/4 -translate-x-1/6"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 py-16 md:py-24 w-full">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-20">

      <!-- Text content (mobile: first, desktop: left) -->
      <div class="text-center md:text-left flex-1 order-last md:order-first">
        <!-- Name -->
        <h1 class="hero-title text-3xl sm:text-4xl md:text-[3.25rem] font-semibold tracking-tight text-[var(--color-primary-dark)] leading-tight">
          {siteConfig.name}
        </h1>

        <!-- Tagline -->
        <p class="hero-subtitle mt-5 text-lg sm:text-xl md:text-2xl font-accent text-[var(--color-primary)] leading-relaxed">
          {siteConfig.hero.tagline}
        </p>

        <!-- Subtitle -->
        <p class="hero-tagline mt-3 text-sm sm:text-base text-[var(--color-primary)] tracking-wide uppercase">
          {siteConfig.hero.subtitle}
        </p>

        <!-- Shimmer divider -->
        <div class="hero-tagline mt-8 w-20 h-[2px] bar-shimmer rounded-full mx-auto md:mx-0"></div>

        <!-- CTA + Social row -->
        <div class="hero-cta mt-8 flex flex-col sm:flex-row items-center md:items-start gap-5">
          <a
            href={`mailto:${siteConfig.hero.cta.email}?subject=${encodeURIComponent(siteConfig.hero.cta.subject)}`}
            class="inline-flex items-center gap-2 px-8 py-3.5 text-base font-medium text-[var(--color-surface-light)] bg-[var(--color-accent)] rounded-full btn-hover"
          >
            {siteConfig.hero.cta.text}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>

          <div class="flex items-center gap-4">
            {siteConfig.social.linkedin && (
              <a
                href={siteConfig.social.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[var(--color-primary)] hover:text-[var(--color-accent)] transition-colors"
                aria-label="LinkedIn"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            )}
            <a
              href={`mailto:${siteConfig.social.email}`}
              class="text-[var(--color-primary)] hover:text-[var(--color-accent)] transition-colors"
              aria-label="Email"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Photo (mobile: top, desktop: right) — bigger for premium feel -->
      <div class="hero-photo shrink-0 order-first md:order-last">
        <div class="w-60 h-60 sm:w-72 sm:h-72 md:w-80 md:h-80 lg:w-[22rem] lg:h-[22rem] rounded-2xl overflow-hidden border-2 border-[var(--color-primary-light)]/20 shadow-2xl shadow-[var(--color-primary-dark)]/10">
          <img
            src="/profile.jpg"
            alt={siteConfig.name}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
</section>
